{
  "openapi": "3.0.0",
  "paths": {
    "/reports": {
      "get": {
        "operationId": "listReports",
        "parameters": [
          {
            "name": "x-tenant-id",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "session",
            "in": "cookie",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer" }
          }
        ]
      }
    }
  }
}
