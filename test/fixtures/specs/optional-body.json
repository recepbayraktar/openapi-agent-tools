{
  "openapi": "3.0.0",
  "paths": {
    "/reports": {
      "post": {
        "operationId": "createReport",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "format": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}
